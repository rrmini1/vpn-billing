APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8083
FRONTEND_URL=http://localhost:8083
APP_PORT=8083
VITE_FORWARD_PORT=5175
VITE_DEV_SERVER_URL=http://localhost:5175
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8083,localhost:5175,127.0.0.1,127.0.0.1:8083,127.0.0.1:5175
CORS_ALLOWED_ORIGINS=http://localhost:8083,http://localhost:5175,http://127.0.0.1:8083,http://127.0.0.1:5175

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=vpn_billing
DB_USERNAME=vpn_billing
DB_PASSWORD=vpn_billing
DB_FORWARD_PORT=5433

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=vpn_billing
REDIS_PORT=6379
REDIS_FORWARD_PORT=6381

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAILHOG_FORWARD_PORT=8025

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=CorsPortMain_bot
TELEGRAM_AUTH_MAX_AGE=86400

PAYMENT_PROVIDER=mock
MOCK_PAYMENT_EXPIRES_IN_MINUTES=30
YOOKASSA_BASE_URL=https://api.yookassa.ru/v3
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL="${FRONTEND_URL}/app/payments"
YOOKASSA_TIMEOUT=10

MARZBAN_BASE_URL=https://panel.cors-port.ru
MARZBAN_USERNAME=
MARZBAN_PASSWORD=
MARZBAN_TIMEOUT=10
MARZBAN_PROXY_TYPE=vless
MARZBAN_INBOUND="VLESS TCP REALITY"
MARZBAN_DATA_LIMIT_RESET_STRATEGY=no_reset

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
